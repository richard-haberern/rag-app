# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# === Docker (docker compose up) ===
# Read by docker-compose.yml for the pg service and the api's DATABASE_URL.
POSTGRES_PASSWORD=change-me

# Vector backend: ChromaDB (default) or Postgres (pgvector). Passed into the api container by
# docker-compose (VECTOR_DB: ${VECTOR_DB:-ChromaDB}); .env is not read inside the container.
# VECTOR_DB=ChromaDB

# === Running the tests against the compose pg (docker compose --profile test up) ===
# Host-run pytest connects as raguser to an isolated rag_test database on the
# published pg (localhost:5432). DB_PASSWORD_TEST must equal POSTGRES_PASSWORD above
# (same role). DB_NAME_TEST is the isolated test database (created by init.sql on a
# fresh volume, or manually once on an existing one).
DB_USER=raguser
DB_PASSWORD_TEST=change-me
DB_NAME_TEST=rag_test

# === Running locally (uvicorn, no Docker) ===
# PostgreSQL — only the password is required; the rest default to the local dev container.
DB_PASSWORD=CHANGE_ME
# DB_USER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ragdb
# Optional full override (takes precedence over the DB_* parts above):
# DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/ragdb

# LLM (generation) — required at startup for both Docker and local; the app builds the
# Gemini client on boot and fails without a key.
LLM_API_KEY=your-gemini-api-key
# LLM_MODEL=gemini-2.5-flash
# LLM_TIMEOUT=60.0

# Embedding model — fixes the pgvector column dimension (see DECISIONS.md).
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384
EMBED_DEVICE=cpu
EMBED_BATCH_SIZE=32

# Chunking. Leave CHUNK_SIZE unset to use the model's full content window; if set it must not
# exceed it. CHUNK_OVERLAP_RATIO is the fraction of chunk_size shared between adjacent chunks.
# CHUNK_SIZE=256
# CHUNK_OVERLAP_RATIO=0.12
