# Copy to .env and fill in. .env is gitignored — never commit real credentials.
# The app reads these via pydantic Settings (config.py); unknown keys are ignored.

# === Docker (docker compose up) ===
# docker-compose.yaml reads these two to build the api's DATABASE_URL (owner, raguser) and
# APP_DATABASE_URL (least-privilege app_user, the role the app connects as so RLS applies).
POSTGRES_PASSWORD=change-me
# Password for the app_user role that `docker compose run --rm pg-init` creates
# (scripts/bootstrap-pg.sh). On prod/Neon, create the role once via the console instead.
APP_USER_PASSWORD=change-me-too

# === Running the tests against the compose pg (docker compose --profile test up) ===
# Host-run pytest reads these two full URLs directly (Settings.test_* fields). raguser is a
# superuser (bypasses RLS, used by the plain `session` fixture); app_user is RLS-enforced
# (used by the app_session/tenant fixtures). Both point at the isolated rag_test database,
# created idempotently by `docker compose run --rm pg-init`. Passwords match the roles above.
TEST_DATABASE_URL=postgresql+asyncpg://raguser:change-me@localhost:5432/rag_test
TEST_APP_DATABASE_URL=postgresql+asyncpg://app_user:change-me-too@localhost:5432/rag_test

# === Running locally (uvicorn, no Docker) ===
# DATABASE_URL      -> owner (raguser) connection, used only by `alembic upgrade head`.
# APP_DATABASE_URL  -> app_user connection, what the running app connects as (RLS applies).
# DATABASE_URL=postgresql+asyncpg://raguser:change-me@localhost:5432/ragdb
# APP_DATABASE_URL=postgresql+asyncpg://app_user:change-me-too@localhost:5432/ragdb
# SSL: leave unset/false for the local + CI/test Postgres (no TLS). Set true for Neon or any
# managed Postgres that requires SSL.
# DB_SSL=true

# === Auth / sessions ===
# SECURE marks the session cookie Secure — set true when serving over HTTPS (e.g. deployed).
# SECURE=true
# SWEEP_TOKEN gates POST /admin/cleanup (the retention sweep). Leave unset to disable the
# endpoint (it 404s without a configured token).
# SWEEP_TOKEN=some-long-secret
# Anonymous-owner retention window and browser cookie max_age (seconds); keep aligned.
# Defaults: 30 days.
# TTL=30
# COOKIE_EXPIRE=2592000

# === LLM (generation) ===
# Required at startup for both Docker and local; the app builds the Gemini client on boot.
LLM_API_KEY=your-gemini-api-key
# LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
# LLM_TIMEOUT=60.0

# === Embedding model — fixes the pgvector column dimension (see DECISIONS.md) ===
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384
EMBED_DEVICE=cpu
EMBED_BATCH_SIZE=32

# === Chunking ===
# Leave CHUNK_SIZE unset to use the model's full content window; if set it must not exceed it.
# CHUNK_OVERLAP_RATIO is the fraction of chunk_size shared between adjacent chunks.
# CHUNK_SIZE=256
# CHUNK_OVERLAP_RATIO=0.12

# === Retrieval ===
# RETRIEVAL_TOP_K=5
# RETRIEVAL_THRESHOLD=0.7
